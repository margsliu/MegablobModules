# Ignore all dotfiles except git dotfiles
.*
!.git*

# Build output
build/
dist/
plugin-build/

# Compiled plugin files
*.vcvplugin
*.so
*.dll
*.dylib

# Object and library files
*.o
*.d
*.a

# Dependencies (generated by `make dep`)
/dep

# VS Code (optional - some teams commit these)
# .vscode/

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# Python cache (from helper.py)
__pycache__/
*.pyc